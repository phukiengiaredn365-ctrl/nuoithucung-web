# WordPress Headless CMS endpoint.
# When empty, the site renders from typed mock data in src/lib/mock-data.ts
# so previews & CI builds work without a live backend.
WP_GRAPHQL_ENDPOINT=
WP_GRAPHQL_AUTH_HEADER=

# Build target:
#   standalone  — Node.js server for cPanel Node.js apps (default)
#   export      — pure static HTML for shared Apache hosting
# Leave unset to default to 'standalone'.
NEXT_OUTPUT=

# Shared public site URL used for canonical metadata + sitemap.
NEXT_PUBLIC_SITE_URL=https://nuoithucung.com
